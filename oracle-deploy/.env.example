# Web dashboard login (change before deploying!)
WEB_USERNAME=admin
WEB_PASSWORD=change-me-now
WEB_SECRET_KEY=generate-a-long-random-string-here

# Port exposed on the host (Oracle VM)
WEB_PORT=8081

# Default MAP merchant credentials (can be changed in the web UI)
MERCHANT_PHONE_OR_EMAIL=08xxxxxxxxxx
MERCHANT_PIN=123456

# Bot settings
ACTION_DELAY_MS=500
CAPTCHA_WAIT_SECONDS=120

# "Jumlah produk" per order, repeating pattern (default 1 per order).
# 1,2,2 sells 1, then 2, then 2, then repeats so stock empties faster.
# Can also be changed from the web dashboard.
QUANTITY_PATTERN=1,2,2

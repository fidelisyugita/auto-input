# Login credentials for MAP (Merchant Apps Pangkalan)
MERCHANT_PHONE_OR_EMAIL=08xxxxxxxxxx
MERCHANT_PIN=123456

# Path to NIK file (.json, .txt one-per-line, or .xlsx with nik column)
NIK_FILE=nik.json

# Browser mode for `run` only (test always opens visible browser)
HEADLESS=false

# Delay between actions in milliseconds (use higher value when testing)
ACTION_DELAY_MS=500

# Max NIKs in test mode (0 = no limit, runs until stock=0 or Ctrl+C)
TEST_LIMIT=200
